# ─── SmartLaw Backend — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your real values
# In Railway: set these in Settings → Variables

# App
APP_ENV=production
APP_SECRET_KEY=change-me-to-random-64-char-string
FRONTEND_URL=https://smartlaw.pages.dev   # your Cloudflare Pages URL

# Supabase — get from: supabase.com → project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (keep secret, backend only)

# Anthropic — get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — get from: aistudio.google.com → API Keys
GOOGLE_API_KEY=AIza...

# OpenAI (Whisper for audio transcription)
OPENAI_API_KEY=sk-...

# Redis (optional for now — leave blank to disable background tasks)
REDIS_URL=
